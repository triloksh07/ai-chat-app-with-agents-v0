{
    "compilerOptions":{
        "target":"ES2020",
        "module":"commonjs",
        "strict":true,
        "noEmit": true,
        "esModuleInterop":true,
        "skipLibCheck":true,
        "forceConsistentCasingInFileNames":true,
        "outDir":"./dist",
        "moduleResolution": "Node",
        "sourceMap": true
    }
}